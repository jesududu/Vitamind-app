<template>
  <div class="page" data-name="login">
    <div class="navbar">
      <div class="navbar-bg"></div>
      <div class="navbar-inner">
        <div class="left"><a href="#" class="link back"><i class="icon icon-back"></i></a></div>
        <div class="title">Login</div>
      </div>
    </div>
    <div class="page-content vm-page-content">
      <div class="vm-form-card">
        <div class="vm-section-title">Iniciar sesion como paciente</div>
        <form class="list no-hairlines-md" @submit=${submitLogin}>
          <ul>
            <li class="item-content item-input">
              <div class="item-inner">
                <div class="item-title item-label">Email</div>
                <div class="item-input-wrap">
                  <input type="email" id="login-email" placeholder="tucorreo@ejemplo.com" />
                </div>
              </div>
            </li>
            <li class="item-content item-input">
              <div class="item-inner">
                <div class="item-title item-label">Contrasena</div>
                <div class="item-input-wrap">
                  <input type="password" id="login-password" placeholder="********" />
                </div>
              </div>
            </li>
          </ul>
        </form>
        <div class="vm-actions">
          <a href="#" class="button button-fill" @click=${submitLogin}>Entrar</a>
        </div>
        <div class="vm-actions">
          <a href="/forgot-password/" class="button button-outline">He olvidado mi contrasena</a>
          <a href="/registro/" class="button button-outline">Crear cuenta</a>
        </div>
      </div>
    </div>
  </div>
</template>
<script>
  import utils from '../js/utils.js';

  export default function (props, { $el, $f7, $store }) {
    const getPageNode = (event = null) => {
      const fromEvent = event && event.target && event.target.closest ? event.target.closest('.page[data-name="login"]') : null;
      if (fromEvent) return fromEvent;
      if ($el && $el[0]) return $el[0];
      if ($el && $el.nodeType === 1) return $el;
      return document.querySelector('.page[data-name="login"].page-current') || document.querySelector('.page[data-name="login"]');
    };

    const submitLogin = async (event) => {
      if (event) event.preventDefault();

      const pageNode = getPageNode(event);
      const emailInput = pageNode ? pageNode.querySelector('#login-email') : null;
      const passwordInput = pageNode ? pageNode.querySelector('#login-password') : null;
      const email = emailInput ? emailInput.value.trim() : '';
      const password = passwordInput ? passwordInput.value : '';

      if (!email || !password) {
        $f7.dialog.alert('Introduce email y contrasena.');
        return;
      }

      try {
        $f7.preloader.show();
        await utils.login({
          email,
          password,
          remember: true,
        });
        $store.dispatch('refreshSession');
        const homeView = $f7.views.get('#view-home');
        if (homeView && homeView.router) {
          homeView.router.navigate('/cli/', {
            reloadCurrent: true,
            ignoreCache: true,
          });
        }
        const settingsView = $f7.views.get('#view-settings');
        if (settingsView && settingsView.router) {
          settingsView.router.navigate('/cli/settings/', {
            reloadCurrent: true,
            ignoreCache: true,
            clearPreviousHistory: true,
          });
        }
        $f7.tab.show('#view-home');
      } catch (error) {
        $f7.dialog.alert(utils.getApiErrorMessage(error, 'No se pudo iniciar sesion'));
      } finally {
        $f7.preloader.hide();
      }
    };

    return $render;
  }
</script>

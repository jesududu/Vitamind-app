{
  "name": "vitamind",
  "private": true,
  "version": "1.0.0",
  "description": "VitaMind",
  "repository": "",
  "license": "UNLICENSED",
  "scripts": {
    "start": "npm run dev",
    "dev": "cross-env NODE_ENV=development vite",
    "build": "cross-env NODE_ENV=production vite build",
    "build-capacitor-ios": "cross-env NODE_ENV=production vite build && npx cap copy ios",
    "build-capacitor-android": "cross-env NODE_ENV=production vite build && npx cap copy android",
    "postinstall": "cpy --flat ./node_modules/framework7-icons/fonts/*.* ./src/fonts/ && cpy --flat ./node_modules/material-icons/iconfont/*.* ./src/fonts/"
  },
  "browserslist": [
    "IOS >= 15",
    "Safari >= 15",
    "last 5 Chrome versions",
    "last 5 Firefox versions"
  ],
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/core": "^8.2.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@capawesome/capacitor-screen-orientation": "^8.0.1",
    "dom7": "^4.0.6",
    "framework7": "^9.0.3",
    "framework7-icons": "^5.0.5",
    "material-icons": "^1.13.14",
    "skeleton-elements": "^4.0.1",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "-": "^0.0.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.2.0",
    "cordova-res": "^0.15.4",
    "cpy-cli": "^7.0.0",
    "cross-env": "^10.1.0",
    "postcss-preset-env": "^11.2.0",
    "rollup-plugin-framework7": "^1.2.1",
    "vite": "^8.0.0"
  }
}
